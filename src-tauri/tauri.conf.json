{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "VibeRacing",
  "version": "0.1.0",
  "identifier": "com.viberacing.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VibeRacing - Co-op Telemetry Simulator",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
